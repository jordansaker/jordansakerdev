# Local dev: matches docker-compose.yml
DATABASE_URL="postgres://studio:studio@localhost:5433/studio"

# Single-user auth — pick a strong password
ADMIN_PASSWORD="change-me"

# 32+ random bytes, hex. Used to sign the session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-something-long-and-random"

# Resend API key (https://resend.com)
RESEND_API_KEY=""
RESEND_FROM="Jordan Saker <jordan@mail.jordansakerdev.com>"

# Public URL used in emails (so links work)
APP_URL="http://localhost:3002"

# Resend Inbound webhook signing secret (from Resend dashboard → Webhooks)
# Point your webhook at https://<APP_URL>/api/inbound/resend
RESEND_WEBHOOK_SECRET=""
